---
import { assets } from '@/data/assets';

const explanationImage = [...assets.cloudinary.desktop, ...assets.cloudinary.tablet, ...assets.cloudinary.mobile]
  .find((asset) => /explanation|load|system|restart|锌械褉械蟹邪谐褉褍蟹泻邪/i.test(`${asset.display_name} ${asset.public_id}`));
---
<section class="section" aria-labelledby="explanation-title"><div class="container explain"><div><p class="eyebrow">袠薪芯谐写邪 褋懈褋褌械屑邪 薪邪褋褌芯谢褜泻芯 锌褉懈胁褘泻邪械褌 卸懈褌褜 胁 薪邪锌褉褟卸械薪懈懈, 褔褌芯 薪邪褔懈薪邪械褌 褋褔懈褌邪褌褜 械谐芯 薪芯褉屑芯泄.</p><h2 id="explanation-title" class="section-title">协褌芯 薪械 胁芯锌褉芯褋<br/><span>褋懈谢褘 胁芯谢懈</span></h2><p>孝褍褌 褍卸械 锌褘褌邪褌褜褋褟 芦锌械褉械褌械褉锌械褌褜禄 斜械褋褋屑褘褋谢械薪薪芯: 胁邪卸薪芯 胁械褉薪褍褌褜 褋械斜械 褋芯褋褌芯褟薪懈械, 胁 泻芯褌芯褉芯屑 锌褉芯写褍泻褌懈胁薪芯褋褌褜 褋薪芯胁邪 褋褌邪薪芯胁懈褌褋褟 胁芯蟹屑芯卸薪芯泄.</p></div>{explanationImage && <img class="load" src={explanationImage.secure_url} alt="" loading="lazy" decoding="async" />}</div></section>
<style>.explain{display:grid;grid-template-columns:1.2fr .8fr;gap:32px;align-items:center}.eyebrow{font-size:clamp(1.1rem,2vw,1.5rem);font-weight:800;color:var(--color-muted);max-width:620px}.load{width:100%;min-height:420px;border-radius:36px;object-fit:cover;display:block}.section-title span{color:#df593e}@media(max-width:800px){.explain{grid-template-columns:1fr}.load{min-height:300px}}</style>
