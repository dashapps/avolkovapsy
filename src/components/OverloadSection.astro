---
import { assets } from '@/data/assets';

const overloadAssets = assets.sections.section1;

if (!overloadAssets.desktop || !overloadAssets.tablet || !overloadAssets.mobile) {
  throw new Error('Missing viewport-specific section1 Cloudinary asset.');
}

const chips = [
  'Голова постоянно занята задачами.',
  'Отдых не даёт ощущения восстановления.',
  'На простые решения уходит больше сил, чем раньше.',
  'Появляется раздражение, усталость или внутренний шум.',
  'Ошибки возникают там, где раньше всё было очевидно.',
  'Кажется, что энергии хватает только на обязательное.',
];
---
<section class="overload" aria-labelledby="overload-title" data-node-id="62:855">
  <div class="overload__stage">
    <picture class="overload__image" data-node-id="62:856" aria-hidden="true">
      <source media="(max-width: 767px)" srcset={overloadAssets.mobile} />
      <source media="(max-width: 1023px)" srcset={overloadAssets.tablet} />
      <img src={overloadAssets.desktop} alt="" loading="lazy" decoding="async" />
    </picture>

    <div class="overload__panel" data-node-id="62:857" aria-hidden="true"></div>

    <h2 id="overload-title" class="overload-title" data-node-id="62:858">
      <span class="overload-title-line overload-title-line--main">Ты справляешься</span>
      <span class="overload-title-line overload-title-line--accent">но какой ценой?</span>
    </h2>
    <div class="overload__line overload__line--1" aria-hidden="true"></div>
    <div class="overload__line overload__line--2" aria-hidden="true"></div>

    <p class="overload__side-text" data-node-id="62:862">
      Можно работать через разговор, через тело или соединять оба подхода — в зависимости от запроса и состояния.
    </p>

    <div class="overload__chips" aria-label="Признаки перегрузки">
      {chips.map((chip, index) => (
        <div class={`overload-chip overload-chip--${index + 1}`} data-chip-index={index + 1}>
          <span class="overload-chip-inner">{chip}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const overload = document.querySelector<HTMLElement>('.overload');
  const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

  const revealObserver = new IntersectionObserver(
    ([entry]) => {
      if (!overload) return;
      if (entry.isIntersecting && entry.intersectionRatio >= 0.3) {
        overload.classList.add('is-visible');
        revealObserver.disconnect();
      }
    },
    { threshold: [0, 0.3] }
  );

  if (overload) {
    if (motionQuery.matches) {
      overload.classList.add('is-visible');
    } else {
      revealObserver.observe(overload);
    }
  }
</script>

<style>
.overload {
  background: var(--bg2color, #d4d1c8);
  height: 751px;
  min-height: 751px;
  overflow: hidden;
  position: relative;
  width: 100%;
}

.overload,
.overload * { box-sizing: border-box; }

.overload__stage {
  height: 751px;
  left: 50%;
  position: absolute;
  top: 0;
  transform: translateX(-50%);
  width: 1280px;
}

.overload__image {
  display: block;
  height: 641px;
  left: 358px;
  opacity: 0.8;
  position: absolute;
  top: 100px;
  width: 563px;
  z-index: 1;
}

.overload__image img {
  display: block;
  height: 100%;
  object-fit: contain;
  object-position: center;
  width: 100%;
}

.overload__panel {
  border: 1px solid var(--dark-baige, #a69684);
  border-radius: 24px;
  height: 512px;
  left: 137px;
  position: absolute;
  top: 177px;
  width: 945px;
  z-index: 2;
}

.overload-title {
  font-family: "Onest", sans-serif;
  font-weight: 900;
  line-height: 1;
  margin: 0;
  position: absolute;
  z-index: 4;
}

.overload-title-line {
  display: block;
  opacity: 0;
  position: absolute;
  white-space: nowrap;
  will-change: transform, opacity;
}

.overload-title-line--main {
  color: var(--just-dark, #5c5958);
  font-size: 90px;
  left: 233px;
  top: 36px;
  transform: translate3d(-72px, 0, 0);
}

.overload-title-line--accent {
  color: var(--dark-baige, #a69684);
  font-size: 68px;
  left: 233px;
  top: 120px;
  transform: translate3d(72px, 0, 0);
}

.overload.is-visible .overload-title-line {
  opacity: 1;
  transform: translate3d(0, 0, 0);
  transition: opacity 320ms ease, transform 520ms cubic-bezier(.2, .8, .2, 1);
}

.overload__line {
  background: var(--just-dark, #5c5958);
  height: 1px;
  left: 140px;
  position: absolute;
  top: 111px;
  width: 910px;
  z-index: 3;
}

.overload__line--2 { display: none; }

.overload__side-text {
  color: var(--dark-baige, #a69684);
  font-family: "Onest", sans-serif;
  font-size: 16px;
  font-weight: 900;
  height: 123px;
  left: 833px;
  line-height: 1.1;
  margin: 0;
  position: absolute;
  top: 207px;
  width: 214px;
  z-index: 4;
}

.overload__chips { inset: 0; position: absolute; z-index: 5; }

.overload-chip {
  background: var(--just-dark, #5c5958);
  border-radius: 24px;
  box-shadow: 8px 18px 1px rgba(176, 156, 134, 0.4);
  color: var(--beigebg, #e5d7c7);
  font-family: "Onest", sans-serif;
  font-size: 18px;
  font-weight: 400;
  line-height: 1.3;
  opacity: 0;
  padding: 18px 36px;
  position: absolute;
  transform: translateY(-24px) rotate(var(--chip-rotate));
  transition: opacity 220ms ease, transform 420ms cubic-bezier(.2, .8, .2, 1);
  transition-delay: var(--chip-delay);
  white-space: nowrap;
  width: max-content;
  will-change: transform, opacity;
}

.overload.is-visible .overload-chip {
  opacity: 1;
  transform: translateY(0) rotate(var(--chip-rotate));
}

.overload-chip-inner { display: block; }
.overload.is-visible .overload-chip-inner {
  animation: overload-chip-wobble 5.5s ease-in-out infinite;
  animation-delay: var(--chip-float-delay);
}

.overload-chip--1 { --chip-delay: 180ms; --chip-float-delay: 0ms; --chip-rotate: 10deg; --chip-wobble-x: 2px; left: 68.79px; top: 196.19px; }
.overload-chip--2 { --chip-delay: 270ms; --chip-float-delay: 220ms; --chip-rotate: 6deg; --chip-wobble-x: -2px; left: 69.13px; top: 289.06px; }
.overload-chip--3 { --chip-delay: 360ms; --chip-float-delay: 440ms; --chip-rotate: -10deg; --chip-wobble-x: 3px; left: 681px; top: 318px; }
.overload-chip--4 { --chip-delay: 450ms; --chip-float-delay: 660ms; --chip-rotate: -3deg; --chip-wobble-x: -3px; left: 629px; top: 489px; }
.overload-chip--5 { --chip-delay: 540ms; --chip-float-delay: 880ms; --chip-rotate: -3deg; --chip-wobble-x: 2px; left: 70px; top: 441px; }
.overload-chip--6 { --chip-delay: 630ms; --chip-float-delay: 1100ms; --chip-rotate: 5deg; --chip-wobble-x: -2px; left: 671.86px; top: 598px; }

@keyframes overload-chip-wobble {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(var(--chip-wobble-x, 3px), 3px) rotate(1.2deg); }
}

@media (max-width: 1023px) {
  .overload { height: 715px; min-height: 715px; }
  .overload__stage { height: 715px; width: 800px; }
  .overload__image { height: 641px; left: 434px; top: 65px; width: 563px; }
  .overload__panel { height: 396px; left: 65px; top: 177px; width: 872px; }
  .overload-title-line--main { font-size: 68px; left: 90px; top: 29px; }
  .overload-title-line--accent { font-size: 42px; left: 176px; top: 117px; }
  .overload__line { left: 0; top: 86px; width: 910px; }
  .overload__line--2 { display: block; top: 152px; }
  .overload__side-text { height: 56px; left: 142px; top: 605px; width: 292px; }
  .overload-chip { font-size: 16px; padding: 12px 36px; }
  .overload-chip--1 { left: 39px; top: 140px; }
  .overload-chip--2 { left: 31px; top: 219px; }
  .overload-chip--3 { --chip-rotate: -3deg; left: 28px; top: 302px; }
  .overload-chip--4 { --chip-rotate: -2deg; left: 312px; top: 375px; }
  .overload-chip--5 { --chip-rotate: 5deg; left: 280px; top: 532px; }
  .overload-chip--6 { --chip-rotate: -3deg; left: 88px; top: 439px; }
}

@media (max-width: 767px) {
  .overload { height: 840px; min-height: 840px; }
  .overload__stage { height: 840px; width: 390px; }
  .overload__image { height: 551px; left: 47px; top: 5px; width: 427px; }
  .overload__panel { height: 552px; left: 65px; top: 140px; width: 355px; }
  .overload-title-line--main { font-size: 36px; left: 26.58px; top: 28px; }
  .overload-title-line--accent { font-size: 24px; left: 12px; top: 56px; }
  .overload__line { left: 0; top: 84.91px; width: 390px; }
  .overload__line--2 { display: none; }
  .overload__side-text { height: 51px; left: 40px; top: 769px; width: 339px; }
  .overload-chip { font-size: 16px; max-width: 330px; padding: 12px 36px; white-space: normal; }
  .overload-chip--1 { left: 6px; top: 160px; }
  .overload-chip--2 { left: 22px; top: 236px; }
  .overload-chip--3 { left: 6px; top: 316px; max-width: 328px; }
  .overload-chip--4 { left: 6px; top: 471px; max-width: 325px; }
  .overload-chip--5 { left: 51px; top: 647px; max-width: 320px; }
  .overload-chip--6 { left: 3px; top: 548px; max-width: 330px; }
}

@media (prefers-reduced-motion: reduce) {
  .overload-title-line,
  .overload-chip,
  .overload-chip-inner {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }
}
</style>
