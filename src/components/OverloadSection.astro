.overload-chip {
  --chip-parallax-x: 0px;
  --chip-parallax-y: 0px;
  background: var(--just-dark, #5c5958);
  border-radius: 24px;
  box-shadow: 8px 18px 1px rgba(176, 156, 134, 0.4);
  color: var(--beigebg, #e5d7c7);
  font-family: var(--font-main, 'Onest', sans-serif);
  font-size: 18px;
  font-weight: 400;
  line-height: 1.3;
  opacity: 0;
  padding: 18px 36px;
  position: absolute;
  white-space: nowrap;
  width: max-content;
  max-width: none;
  transform: translate3d(var(--chip-enter-x, 0), -26px, 0) rotate(var(--chip-rotate));
  transition:
    opacity 260ms ease,
    transform 420ms cubic-bezier(.2, .8, .2, 1);
  transition-delay: var(--chip-delay);
  will-change: transform, opacity;
}

.overload.is-visible .overload-chip {
  opacity: 1;
  transform: translate3d(var(--chip-parallax-x), var(--chip-parallax-y), 0) rotate(var(--chip-rotate));
}

.overload-chip-inner {
  display: block;
}

.overload.is-visible .overload-chip-inner {
  animation: overload-chip-wobble 5.5s ease-in-out infinite;
  animation-delay: var(--chip-float-delay);
}

.overload-chip--1 {
  --chip-delay: 80ms;
  --chip-float-delay: 0ms;
  --chip-rotate: 10deg;
  --chip-wobble-x: 2px;
  left: 79px;
  top: 196px;
}

.overload-chip--2 {
