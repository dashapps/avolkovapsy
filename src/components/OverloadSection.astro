---
import { assets } from '@/data/assets';

const chips = [
  'Голова постоянно занята задачами.',
  'Отдых не даёт ощущения восстановления.',
  'На простые решения уходит больше сил, чем раньше.',
  'Отдых не даёт ощущения восстановления.',
  'Ошибки возникают там, где раньше всё было очевидно.',
  'Кажется, что энергии хватает только на обязательное.',
];
---
<section class="overload" aria-labelledby="overload-title" data-node-id="62:855">
  <div class="overload__stage">
    <picture class="overload__image" data-node-id="62:856" aria-hidden="true">
      <source media="(max-width: 767px)" srcset={assets.sections.section1.mobile} />
      <source media="(max-width: 1023px)" srcset={assets.sections.section1.tablet} />
      <img src={assets.sections.section1.desktop} alt="" loading="lazy" decoding="async" />
    </picture>

    <div class="overload__panel" data-node-id="62:857" aria-hidden="true"></div>

    <div class="overload__headline" data-node-id="62:858">
      <h2 id="overload-title" data-node-id="62:859">
        <span class="overload__headline-main">Ты справляешься</span>
        <span class="overload__headline-sub">но какой ценой?</span>
      </h2>
      <div class="overload__headline-line" data-node-id="62:861" aria-hidden="true"></div>
    </div>

    <p class="overload__side-text" data-node-id="62:862">
      Можно работать через разговор, через тело или соединять оба подхода — в зависимости от запроса и состояния.
    </p>

    <div class="overload__chips" aria-label="Признаки перегрузки">
      {chips.map((chip, index) => (
        <div class={`overload-chip overload-chip--${index + 1}`} data-chip-index={index + 1}>
          <span class="overload-chip-inner">{chip}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const overload = document.querySelector<HTMLElement>('.overload');
  const chips = Array.from(document.querySelectorAll<HTMLElement>('.overload-chip'));
  const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
  let frame = 0;

  const revealObserver = new IntersectionObserver(
    ([entry]) => {
      if (!overload) return;
      if (entry.isIntersecting) {
        overload.classList.add('is-visible');
        revealObserver.disconnect();
      }
    },
    { threshold: 0.24 }
  );

  if (overload) {
    if (motionQuery.matches) {
      overload.classList.add('is-visible');
    } else {
      revealObserver.observe(overload);
    }
  }

  const updateParallax = () => {
    frame = 0;
    if (!overload || motionQuery.matches || !overload.classList.contains('is-visible')) return;

    const rect = overload.getBoundingClientRect();
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
    const progress = Math.max(-1, Math.min(1, (viewportHeight / 2 - rect.top - rect.height / 2) / rect.height));

    chips.forEach((chip, index) => {
      const direction = index % 2 === 0 ? 1 : -1;
      chip.style.setProperty('--chip-parallax-y', `${(progress * 8 * direction).toFixed(2)}px`);
      chip.style.setProperty('--chip-parallax-x', `${(progress * 4 * -direction).toFixed(2)}px`);
    });
  };

  const requestParallax = () => {
    if (frame) return;
    frame = window.requestAnimationFrame(updateParallax);
  };

  window.addEventListener('scroll', requestParallax, { passive: true });
  window.addEventListener('resize', requestParallax);
  requestParallax();
</script>

