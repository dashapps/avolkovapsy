---
import { assets } from '@/data/assets';
const sectionAssets = assets.sections.problems;
if (!sectionAssets?.desktop || !sectionAssets?.tablet || !sectionAssets?.mobile) throw new Error('Missing required asset key: assets.sections.problems.desktop/tablet/mobile');
---
<section class="poster-section problems-section" aria-labelledby="problems-title" data-node-id="62:878">
  <div class="poster-stage">
    <picture class="poster-image problems-image" aria-hidden="true"><source media="(max-width: 767px)" srcset={sectionAssets.mobile} /><source media="(max-width: 1023px)" srcset={sectionAssets.tablet} /><img src={sectionAssets.desktop} alt="" loading="lazy" decoding="async" /></picture>
    <div class="poster-panel" aria-hidden="true"></div>
    <h2 id="problems-title" class="poster-title problems-title"><span>Что происходит</span><strong>на&nbsp;самом деле</strong></h2>
    <div class="poster-line" aria-hidden="true"></div>
    <p class="problems-top">Проблема не&nbsp;всегда<br />в&nbsp;количестве задач</p>
    <p class="problems-middle">Когда напряжение становится постоянным фоном, всё больше ресурсов уходит на&nbsp;то, чтобы просто держаться<br class="problems-mobile-break" /> в&nbsp;рабочем состоянии.</p>
    <p class="problems-bottom">На&nbsp;ясность, внимание, восстановление, отношения<br />и&nbsp;новые решения остаётся меньше энергии.</p>
  </div>
</section>

<style>
.poster-section{box-sizing:border-box;opacity:1;overflow:hidden;position:relative;transform:none;width:100%}.poster-section *{box-sizing:border-box}.poster-stage{height:100%;left:50%;position:absolute;top:0;transform:translateX(-50%);width:1280px}.poster-image{display:block;overflow:hidden;position:absolute;z-index:1}.poster-image img{display:block;height:100%;object-fit:contain;object-position:center;width:100%}.poster-panel{border:1px solid var(--dark-baige,#a69684);border-radius:24px;position:absolute;z-index:2}.poster-title{font-family:var(--font-main,'Onest',sans-serif);font-weight:900;line-height:1;margin:0;position:absolute;z-index:4}.poster-title span,.poster-title strong{display:block;font:inherit;white-space:nowrap}.poster-title span{color:var(--just-dark,#5c5958)}.poster-line{background:var(--just-dark,#5c5958);height:1px;position:absolute;z-index:3}.problems-section{background:var(--bg2color,#d4d1c8);height:752px;min-height:752px}.problems-image{height:804px;left:-217px;opacity:.9;top:18px;width:1434px}.problems-section .poster-panel{height:542px;left:405px;top:76px;width:728px}.problems-title{height:157px;left:179px;top:341px;width:909px}.problems-title span{font-size:90px}.problems-title strong{color:var(--brown-accent,#ba872c);font-size:68px}.problems-section .poster-line{left:90px;top:416px;width:1043px}.problems-top,.problems-middle,.problems-bottom{color:var(--just-dark,#5c5958);font-family:var(--font-main,'Onest',sans-serif);line-height:1.1;margin:0;position:absolute;z-index:4}.problems-top{font-size:24px;font-weight:700;left:758px;top:106px;width:253px}.problems-middle{font-size:22px;font-weight:400;left:758px;top:188px;width:330px}.problems-bottom{font-size:22px;font-weight:400;left:758px;top:498px;width:330px}@media(max-width:1023px){.poster-image img{object-fit:cover}.poster-stage{width:800px}.problems-section{height:839px;min-height:839px}.problems-image{left:-497px}.problems-section .poster-panel{height:546px;left:115px;top:72px}.problems-title{left:33px;top:310px}.problems-section .poster-line{left:-56px;top:385px}.problems-top{left:418px}.problems-middle{left:418px}.problems-bottom{left:418px}}@media(max-width:767px){.poster-stage{width:390px}.problems-image{height:641px;left:-436px;top:247px;width:1143px}.problems-section .poster-panel{height:603px;left:72px;top:67px;width:399px}.problems-title{left:6px;top:301px}.problems-title span{font-size:48px}.problems-title strong{font-size:32px}.problems-title strong{margin-top:0}.problems-section .poster-line{left:-46px;top:341px}.problems-top{left:115px;top:109px;width:253px}.problems-middle{left:115px;top:171px;width:237px}.problems-bottom{left:213px;top:497px;width:155px}}
</style>
