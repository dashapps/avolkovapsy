---
import { assets } from '@/data/assets';
const sectionAssets = assets.sections.problems;
if (!sectionAssets?.desktop || !sectionAssets?.tablet || !sectionAssets?.mobile) throw new Error('Missing required asset key: assets.sections.problems.desktop/tablet/mobile');
---
<section class="problems-section" aria-labelledby="problems-title" data-node-id="62:878" data-problems-section>
  <div class="problems-stage">
    <picture class="problems-image" aria-hidden="true">
      <source media="(max-width: 767px)" srcset={sectionAssets.mobile} />
      <source media="(max-width: 1023px)" srcset={sectionAssets.tablet} />
      <img src={sectionAssets.desktop} alt="" loading="lazy" decoding="async" />
    </picture>
    <div class="problems-panel" aria-hidden="true"></div>
    <h2 id="problems-title" class="problems-title">
      <span class="problems-title-line problems-title-line--main">Что происходит</span>
      <strong class="problems-title-line problems-title-line--accent">на самом деле</strong>
    </h2>
    <div class="problems-line" aria-hidden="true"></div>
    <p class="problems-top">Проблема не всегда<br />в количестве задач</p>
    <p class="problems-middle">Когда напряжение становится постоянным фоном, всё больше ресурсов уходит на то, чтобы просто держаться в рабочем состоянии.</p>
    <p class="problems-bottom">На ясность, внимание, восстановление, отношения<br />и новые решения остаётся меньше энергии.</p>
  </div>
</section>
<script>
  const section = document.querySelector<HTMLElement>('[data-problems-section]');

  if (section) {
    if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      section.classList.add('is-visible');
    } else {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting && entry.intersectionRatio >= 0.3) {
            section.classList.add('is-visible');
            observer.disconnect();
          }
        },
        { threshold: [0, 0.3] }
      );

      observer.observe(section);
    }
  }
</script>
<style>
.problems-section{box-sizing:border-box;background:var(--bg2color,#d4d1c8);height:752px;min-height:752px;overflow:hidden;position:relative;width:100%}.problems-section *{box-sizing:border-box}.problems-stage{height:100%;left:50%;position:absolute;top:0;transform:translateX(-50%);width:1280px}.problems-image{display:block;height:804px;left:-217px;opacity:.9;overflow:hidden;position:absolute;top:18px;width:1434px;z-index:1}.problems-image img{display:block;height:100%;object-fit:contain;object-position:center;width:100%}.problems-panel{border:1px solid var(--dark-baige,#a69684);border-radius:24px;height:542px;left:405px;position:absolute;top:76px;width:728px;z-index:2}.problems-title{font-family:var(--font-main,'Onest',sans-serif);font-weight:900;line-height:1;margin:0;position:absolute;z-index:4}.problems-title-line{display:block;font:inherit;line-height:1;opacity:0;transition:opacity 320ms ease,transform 520ms cubic-bezier(.2,.8,.2,1);white-space:nowrap}.problems-title-line--main{color:var(--just-dark,#5c5958);font-size:90px;height:90px;left:179px;position:absolute;top:341px;transform:translate3d(-72px,0,0);width:729px}.problems-title-line--accent{color:var(--brown-accent,#ba872c);font-size:68px;height:68px;left:179px;position:absolute;top:420px;transform:translate3d(72px,0,0);transition-delay:90ms;width:502px}.problems-section.is-visible .problems-title-line{opacity:1;transform:translate3d(0,0,0)}.problems-line{background:var(--just-dark,#5c5958);height:1px;left:90px;position:absolute;top:416px;width:1043px;z-index:3}.problems-top,.problems-middle,.problems-bottom{color:var(--just-dark,#5c5958);font-family:var(--font-main,'Onest',sans-serif);line-height:1.1;margin:0;position:absolute;z-index:4}.problems-top{font-size:24px;font-weight:700;height:52px;left:758px;top:106px;width:253px}.problems-middle{font-size:22px;font-weight:400;height:120px;left:758px;top:188px;width:330px}.problems-bottom{font-size:22px;font-weight:400;height:96px;left:758px;top:498px;width:330px}@media(max-width:1023px){.problems-section{height:839px;min-height:839px}.problems-stage{width:800px}.problems-image{left:-497px}.problems-panel{height:546px;left:115px;top:72px;width:728px}.problems-title-line--main{left:33px;top:310px}.problems-title-line--accent{left:33px;top:389px}.problems-line{left:-56px;top:385px}.problems-top{left:418px;top:106px}.problems-middle{left:418px;top:188px}.problems-bottom{left:418px;top:498px}}@media(max-width:767px){.problems-stage{width:390px}.problems-image{height:641px;left:-436px;top:247px;width:1143px}.problems-panel{height:603px;left:72px;top:67px;width:399px}.problems-title-line--main{font-size:48px;height:48px;left:6px;top:301px;width:389px}.problems-title-line--accent{font-size:32px;height:32px;left:6px;top:349px;width:236px}.problems-line{left:-46px;top:341px}.problems-top{font-size:18px;height:40px;left:115px;top:109px;width:253px}.problems-middle{font-size:18px;height:120px;left:115px;top:171px;width:237px}.problems-bottom{font-size:18px;height:142px;left:213px;top:497px;width:155px}}@media(prefers-reduced-motion:reduce){.problems-title-line{opacity:1!important;transform:none!important;transition:none!important}}
</style>
