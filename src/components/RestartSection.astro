      left: -39px;
      top: 0;
      width: 1358px;
      height: 741px;
    }

    .restart-panel {
      left: 109px;
      top: 38px;
      width: 987px;
      height: 410px;
    }

    .restart-title {
      left: 91px;
      top: 305px;
      width: 648px;
    }

    .restart-title-line--main {
      width: 648px;
      height: 90px;
      font-size: 90px;
    }

    .restart-title-line--accent {
      left: 47px;
      top: 86px;
      width: 356px;
      height: 68px;
      font-size: 68px;
    }

    .restart-line {
      left: 0;
      top: 380px;
      width: 910px;
    }

    .restart-intro {
      left: 138px;
      top: 63px;
      width: 242px;
      height: 205px;
      font-size: 28px;
    }

    .restart-bottom {
      left: 138px;
