      height: 32px;
      font-size: 32px;
    }

    .restart-line {
      left: -12px;
      top: 241px;
      width: 910px;
    }

    .restart-intro {
      left: 65px;
      top: 69px;
      width: 280px;
      height: 123px;
      font-size: 22px;
    }

    .restart-bottom {
      left: 239px;
      top: 474px;
      width: 121px;
      height: 142px;
      font-size: 18px;
    }

    .restart-bottom-break {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .restart-title-line {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
