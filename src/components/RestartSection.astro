---
import { assets } from '@/data/assets';

const sectionAssets = assets.sections.restart;
if (!sectionAssets?.desktop || !sectionAssets?.tablet || !sectionAssets?.mobile) {
  throw new Error('Missing required asset key: assets.sections.restart.desktop/tablet/mobile');
}
---
<section class="restart" aria-labelledby="restart-title" data-node-id="62:869" data-restart-section>
  <div class="restart-stage">
    <picture class="restart-image" aria-hidden="true">
      <source media="(max-width: 767px)" srcset={sectionAssets.mobile} />
      <source media="(max-width: 1023px)" srcset={sectionAssets.tablet} />
      <img src={sectionAssets.desktop} alt="" loading="lazy" decoding="async" />
    </picture>
    <div class="restart-panel" aria-hidden="true"></div>
    <p class="restart-intro">
      Иногда система настолько привыкает жить в&nbsp;напряжении, что начинает считать его нормой.
    </p>
    <h2 id="restart-title" class="restart-title">
      <span class="restart-title-line restart-title-line--main">Это не вопрос</span>
      <strong class="restart-title-line restart-title-line--accent">силы воли</strong>
    </h2>
    <div class="restart-line" aria-hidden="true"></div>
    <p class="restart-bottom">
      Ты уже платишь за&nbsp;перегруз.<br class="restart-bottom-break" />
      Возможно, просто ещё не&nbsp;считаешь эту цену.
    </p>
  </div>
</section>
<script>
  const section = document.querySelector<HTMLElement>('[data-restart-section]');

  if (section) {
    if (!('IntersectionObserver' in window)) {
      section.classList.add('is-visible');
    } else {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting && entry.intersectionRatio >= 0.3) {
            section.classList.add('is-visible');
            observer.disconnect();
          }
        },
        { threshold: [0, 0.3] }
      );

      observer.observe(section);
    }
  }
</script>
<style>
  .restart,
  .restart * {
    box-sizing: border-box;
  }

  .restart {
    position: relative;
    height: 741px;
    min-height: 741px;
    overflow: hidden;
    background: var(--bg2color, #d4d1c8);
    opacity: 1;
    transform: none;
  }

  .restart-stage {
    position: absolute;
    top: 0;
    left: 50%;
    width: 1280px;
    height: 100%;
    transform: translateX(-50%);
  }

  .restart-image {
    position: absolute;
    z-index: 1;
    display: block;
    overflow: hidden;
    left: -39px;
    top: 0;
    width: 1358px;
    height: 741px;
  }

  .restart-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .restart-panel {
    position: absolute;
    z-index: 2;
    left: 202px;
    top: 38px;
    width: 894px;
    height: 410px;
    border: 1px solid var(--dark-baige, #a69684);
    border-radius: 24px;
  }

  .restart-title {
    position: absolute;
    z-index: 4;
    left: 187px;
    top: 305px;
    width: 648px;
    margin: 0;
    font-family: var(--font-main, 'Onest', sans-serif);
    font-weight: 900;
    line-height: 1;
  }

  .restart-title-line {
    display: block;
    font: inherit;
    line-height: 1;
    white-space: nowrap;
    opacity: 0;
    transition:
      opacity 320ms ease,
      transform 520ms cubic-bezier(.2, .8, .2, 1);
  }

  .restart-title-line--main {
    width: 648px;
    height: 90px;
    color: var(--just-dark, #5c5958);
    font-size: 90px;
    transform: translate3d(-72px, 0, 0);
  }

  .restart-title-line--accent {
    position: absolute;
    left: 15px;
    top: 86px;
    width: 356px;
    height: 68px;
    color: var(--negative, #f25d34);
    font-size: 68px;
    transform: translate3d(72px, 0, 0);
    transition-delay: 90ms;
  }

  .restart.is-visible .restart-title-line {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .restart-line {
    position: absolute;
    z-index: 3;
    left: 96px;
    top: 380px;
    width: 910px;
    height: 1px;
    background: var(--just-dark, #5c5958);
  }

  .restart-intro,
  .restart-bottom {
    position: absolute;
    z-index: 4;
    margin: 0;
    font-family: var(--font-main, 'Onest', sans-serif);
    line-height: 1.1;
  }

  .restart-intro {
    left: 251px;
    top: 69px;
    width: 496px;
    height: 163px;
    color: var(--dark-baige, #a69684);
    font-size: 36px;
    font-weight: 500;
  }

  .restart-bottom {
    left: 252px;
    top: 498px;
    width: 532px;
    height: 79px;
    color: var(--just-dark, #5c5958);
    font-size: 24px;
    font-weight: 400;
  }

