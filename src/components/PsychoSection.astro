---
import { assets } from '@/data/assets';
const sectionAssets = assets.sections.psycho;
if (!sectionAssets?.desktop || !sectionAssets?.tablet || !sectionAssets?.mobile) throw new Error('Missing required asset key: assets.sections.psycho.desktop/tablet/mobile');
---
<section class="poster-section psycho-section" aria-label="Психологический подход" data-node-id="62:893">
  <div class="poster-stage">
    <picture class="poster-image psycho-image" aria-hidden="true"><source media="(max-width: 767px)" srcset={sectionAssets.mobile} /><source media="(max-width: 1023px)" srcset={sectionAssets.tablet} /><img src={sectionAssets.desktop} alt="" loading="lazy" decoding="async" /></picture>
    <div class="poster-panel" aria-hidden="true"></div>
    <p class="psycho-accent">Верни себе ясность, ресурс<br />и&nbsp;внутреннюю устойчивость —</p>
    <p class="psycho-main">работая не&nbsp;только<br />с&nbsp;психикой,<br />но&nbsp;и&nbsp;с&nbsp;телесным напряжением</p>
  </div>
</section>
<style>
.poster-section{box-sizing:border-box;opacity:1;overflow:hidden;position:relative;transform:none;width:100%}.poster-section *{box-sizing:border-box}.poster-stage{height:100%;left:50%;position:absolute;top:0;transform:translateX(-50%);width:1280px}.poster-image{display:block;overflow:hidden;position:absolute;z-index:1}.poster-image img{display:block;height:100%;object-fit:cover;object-position:center;width:100%}.poster-panel{border:1px solid var(--dark-baige,#a69684);border-radius:24px;position:absolute;z-index:2}.psycho-section{background:var(--bg1,#dbd9d2);height:672px;min-height:672px}.psycho-image{height:671px;left:0;top:.83px;width:1280px}.psycho-section .poster-panel{height:431px;left:165px;top:60.83px;width:768px}.psycho-accent,.psycho-main{font-family:var(--font-main,'Onest',sans-serif);font-size:24px;font-weight:500;line-height:1;margin:0;position:absolute;text-align:left;z-index:4}.psycho-accent{color:var(--text-assent,#ba872c);height:75px;left:254px;top:111.83px;width:232px}.psycho-main{color:var(--just-dark,#5c5958);left:254px;top:226.83px;width:334px}@media(max-width:1023px){.poster-stage{width:800px}.psycho-section{height:727px;min-height:727px}.psycho-image{height:727px;left:-316px;top:0;width:1388px}.psycho-section .poster-panel{height:621px;left:-41px;top:38px;width:751px}.psycho-accent{font-size:24px;height:107px;left:79px;top:257px;width:305px}.psycho-main{font-size:24px;height:133px;left:491px;top:433px;width:199px}}@media(max-width:767px){.poster-stage{width:388px}.psycho-section{height:459px;min-height:459px}.psycho-image{height:459px;left:-251px;top:0;width:876px}.psycho-section .poster-panel{height:414px;left:-359px;top:21px;width:708px}.psycho-accent{font-size:16px;height:91px;left:19px;top:33px;width:145px}.psycho-main{font-size:16px;height:133px;left:19px;top:144px;width:199px}}
</style>
