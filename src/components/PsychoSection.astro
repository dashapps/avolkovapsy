---
import { assets } from '@/data/assets';
const sectionAssets = assets.sections.psycho;
if (!sectionAssets?.desktop || !sectionAssets?.tablet || !sectionAssets?.mobile) throw new Error('Missing required asset key: assets.sections.psycho.desktop/tablet/mobile');
---
<section class="poster-section psycho-section" aria-label="Психологический подход" data-node-id="62:893">
  <div class="poster-stage">
    <picture class="poster-image psycho-image" aria-hidden="true"><source media="(max-width: 767px)" srcset={sectionAssets.mobile} /><source media="(max-width: 1023px)" srcset={sectionAssets.tablet} /><img src={sectionAssets.desktop} alt="" loading="lazy" decoding="async" /></picture>
    <div class="poster-panel" aria-hidden="true"></div>
  </div>
</section>
<script>
  document.querySelectorAll<HTMLElement>('.poster-section').forEach((section) => { if (section.dataset.posterRevealBound) return; section.dataset.posterRevealBound='true'; if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { section.classList.add('is-visible'); return; } const observer=new IntersectionObserver(([entry])=>{ if(entry.isIntersecting){ section.classList.add('is-visible'); observer.disconnect(); } },{threshold:0.18}); observer.observe(section); });
</script>
<style>
.poster-section{box-sizing:border-box;opacity:0;overflow:hidden;position:relative;transform:translateY(16px);transition:opacity 360ms ease,transform 420ms ease;width:100%}.poster-section.is-visible{opacity:1;transform:translateY(0)}.poster-section *{box-sizing:border-box}.poster-stage{height:100%;left:50%;position:absolute;top:0;transform:translateX(-50%);width:1280px}.poster-image{display:block;overflow:hidden;position:absolute;z-index:1}.poster-image img{display:block;height:100%;object-fit:contain;object-position:center;width:100%}.poster-panel{border:1px solid var(--dark-baige,#a69684);border-radius:24px;position:absolute;z-index:2}.psycho-section{background:var(--bg2color,#d4d1c8);height:809px;min-height:809px}.psycho-image{height:809px;left:0;top:0;width:1544px}.psycho-section .poster-panel{height:555px;left:718px;top:117px;width:569px}@media(max-width:1023px){.poster-stage{width:800px}.psycho-section{height:727px;min-height:727px}.psycho-image{height:727px;left:-316px;top:0;width:1388px}.psycho-section .poster-panel{height:621px;left:710px;top:38px;width:751px}}@media(max-width:767px){.poster-stage{width:388px}.psycho-section{height:459px;min-height:459px}.psycho-image{height:459px;left:-251px;top:0;width:876px}.psycho-section .poster-panel{height:414px;left:349px;top:21px;width:708px}}@media(prefers-reduced-motion:reduce){.poster-section{opacity:1;transform:none;transition:none}}
</style>
