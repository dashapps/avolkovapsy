---
import Logo from '@/components/Logo.astro';
import { PRIMARY_CONTACT_LINK } from '@/data/site';
---
<header class="header-shell" data-header-mode="scroll" data-node-id="84:363">
  <nav class="site-header" aria-label="Основная навигация">
    <a class="site-header__logo" href="#top" aria-label="Александра Волкова — к началу страницы">
      <Logo />
    </a>

    <a class="site-header__cta" href={PRIMARY_CONTACT_LINK}>Записаться</a>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.header-shell');
  const hero = document.querySelector<HTMLElement>('.hero, #top');

  const updateHeaderVisibility = () => {
    if (!header) return;

    if (header.dataset.headerMode === 'visible') {
      header.classList.add('is-visible');
      return;
    }

    if (!hero) {
      header.classList.add('is-visible');
      return;
    }

    const threshold = hero.offsetHeight * 0.5;
    header.classList.toggle('is-visible', window.scrollY > threshold);
  };

  updateHeaderVisibility();
  window.addEventListener('scroll', updateHeaderVisibility, { passive: true });
  window.addEventListener('resize', updateHeaderVisibility);
</script>

<style>
.header-shell {
  box-sizing: border-box;
  left: 0;
  opacity: 0;
  padding: 24px 24px 12px;
  pointer-events: none;
  position: fixed;
  right: 0;
  top: 0;
  transform: translateY(-120%);
  transition:
    transform 220ms ease,
    opacity 220ms ease;
  width: 100%;
  z-index: 50;
}

.header-shell *,
.header-shell *::before,
.header-shell *::after {
  box-sizing: border-box;
}

.header-shell.is-visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.site-header {
  align-items: flex-end;
  backdrop-filter: blur(8px);
  background: rgba(255, 255, 255, 0.5);
  border-radius: 80px;
  box-shadow: 0 4px 4px rgba(92, 89, 88, 0.48);
  display: flex;
  justify-content: space-between;
  margin: 0 auto;
  max-width: 1220.998px;
  min-height: 79.951px;
  padding: 12px 24px;
  width: 100%;
}

.site-header__logo {
  align-items: center;
  color: var(--just-dark, #5c5958);
  display: inline-flex;
  min-width: 0;
  text-decoration: none;
}

.site-header__cta {
  align-items: center;
  background: var(--primary, #fab842);
  border-radius: 24px;
  color: var(--just-dark, #5c5958);
  display: inline-flex;
  font-family: var(--font-main, 'Onest', sans-serif);
  font-size: 21px;
  font-weight: 600;
  justify-content: center;
  line-height: 1.3;
  padding: 12px 24px;
  text-decoration: none;
  transition: transform 0.2s ease;
  white-space: nowrap;
}

.site-header__cta:hover,
.site-header__cta:focus-visible {
  transform: translateY(-2px);
}

@media (max-width: 600px) {
  .site-header {
    min-height: 80px;
  }
}
</style>
