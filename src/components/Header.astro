---
import { PRIMARY_CONTACT_LINK } from '@/data/site';
---
<header class="header-shell" data-header-mode="scroll" data-node-id="84:363">
  <nav class="site-header" aria-label="Основная навигация">
    <a class="site-header__logo" href="#top" aria-label="Александра Волкова — к началу страницы">
      <span class="logo-battery" aria-hidden="true">
        <span class="logo-battery__bar"></span>
        <span class="logo-battery__bar"></span>
        <span class="logo-battery__bar"></span>
        <span class="logo-battery__bar"></span>
        <span class="logo-battery__bar"></span>
      </span>
      <span class="site-header__logo-text site-header__logo-text--full">Александра<br />ВОлкова</span>
      <span class="site-header__logo-text site-header__logo-text--short">АВ</span>
    </a>

    <a class="site-header__cta" href={PRIMARY_CONTACT_LINK}>Записаться</a>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.header-shell');
  const hero = document.querySelector<HTMLElement>('.hero, #top');

  const updateHeaderVisibility = () => {
    if (!header) return;

    if (header.dataset.headerMode === 'visible') {
      header.classList.add('is-visible');
      return;
    }

    if (!hero) {
      header.classList.add('is-visible');
      return;
    }

    const threshold = hero.offsetHeight * 0.5;
    header.classList.toggle('is-visible', window.scrollY > threshold);
  };

  updateHeaderVisibility();
  window.addEventListener('scroll', updateHeaderVisibility, { passive: true });
  window.addEventListener('resize', updateHeaderVisibility);
</script>

<style>
.header-shell {
  box-sizing: border-box;
  left: 0;
  opacity: 0;
  padding: 24px 24px 12px;
  pointer-events: none;
  position: fixed;
  right: 0;
  top: 0;
  transform: translateY(-120%);
  transition:
    transform 220ms ease,
    opacity 220ms ease;
  width: 100%;
  z-index: 50;
}

.header-shell *,
.header-shell *::before,
.header-shell *::after {
  box-sizing: border-box;
}

.header-shell.is-visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.site-header {
  align-items: flex-end;
  backdrop-filter: blur(8px);
  background: rgba(255, 255, 255, 0.5);
  border-radius: 80px;
  box-shadow: 0 4px 4px rgba(92, 89, 88, 0.48);
  display: flex;
  justify-content: space-between;
  margin: 0 auto;
  max-width: 1220.998px;
  min-height: 79.951px;
  padding: 12px 24px;
  width: 100%;
}

.site-header__logo {
  align-items: center;
  color: var(--just-dark);
  display: inline-flex;
  gap: 14px;
  min-width: 0;
  text-decoration: none;
}

.logo-battery {
  align-items: center;
  animation: battery-twitch 4.8s ease-in-out infinite;
  background: var(--bg1);
  border: 1px solid var(--primary);
  border-radius: 4px;
  display: inline-flex;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 2px;
  height: 55px;
  justify-content: center;
  padding: 4px 1px;
  transform: rotate(35deg);
  transform-origin: center;
  width: 19px;
}

.logo-battery__bar {
  background: var(--primary);
  border-radius: 2px;
  display: block;
  height: 7px;
  width: 15px;
}

.site-header__logo-text {
  font-family: var(--font-main);
  font-size: 32px;
  font-weight: 900;
  line-height: 0.9;
  text-shadow: 6px 12px 2px rgba(176, 156, 134, 0.4);
  text-transform: uppercase;
}

.site-header__logo-text--short {
  color: var(--cardtxtbg);
  display: none;
  letter-spacing: -6.4px;
  line-height: 1.3;
}

.site-header__cta {
  align-items: center;
  background: var(--primary);
  border-radius: 24px;
  color: var(--just-dark);
  display: inline-flex;
  font-family: var(--font-main);
  font-size: 21px;
  font-weight: 600;
  justify-content: center;
  line-height: 1.3;
  padding: 12px 24px;
  text-decoration: none;
  transition: transform 0.2s ease;
  white-space: nowrap;
}

.site-header__cta:hover,
.site-header__cta:focus-visible {
  transform: translateY(-2px);
}

@keyframes battery-twitch {
  0%, 86%, 100% {
    transform: rotate(35deg) translate(0, 0);
  }
  88% {
    transform: rotate(32deg) translate(-1px, 1px);
  }
  90% {
    transform: rotate(38deg) translate(1px, -1px);
  }
  92% {
    transform: rotate(34deg) translate(0, 1px);
  }
  94% {
    transform: rotate(35deg) translate(0, 0);
  }
}

@media (max-width: 600px) {
  .header-shell {
    padding: 24px 24px 12px;
  }

  .site-header {
    min-height: 80px;
  }

  .site-header__logo {
    gap: 12px;
  }

  .site-header__logo-text--full {
    display: none;
  }

  .site-header__logo-text--short {
    display: inline-block;
  }
}

@media (prefers-reduced-motion: reduce) {
  .logo-battery {
    animation: none;
  }
}
</style>
