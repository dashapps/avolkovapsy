---
import { assets } from '@/data/assets';
const sectionAssets = assets.sections.product;
if (!sectionAssets?.desktop || !sectionAssets?.tablet || !sectionAssets?.mobile) throw new Error('Missing required asset key: assets.sections.product.desktop/tablet/mobile');
---
<section class="product" aria-label="О способе работы" data-node-id="62:888">
  <div class="product-stage">
    <picture class="product-image" aria-hidden="true">
      <source media="(max-width: 767px)" srcset={sectionAssets.mobile} />
      <source media="(max-width: 1023px)" srcset={sectionAssets.tablet} />
      <img src={sectionAssets.desktop} alt="" loading="lazy" decoding="async" />
    </picture>
    <div class="product-panel" aria-hidden="true"></div>
    <p class="product-text product-text-1">Чтобы вернуть состояние,<br />в котором продуктивность снова становится возможной,</p>
    <p class="product-text product-text-2">важно работать<br />не только через разговор.</p>
  </div>
</section>
<style>
.product{background:var(--bg-product,#cfcdc6);box-sizing:border-box;height:650px;min-height:650px;overflow:hidden;position:relative;width:100%}.product *{box-sizing:border-box}.product-stage{height:100%;left:50%;position:absolute;top:0;transform:translateX(-50%);width:1280px}.product-image{display:block;height:666px;left:139px;opacity:.8;overflow:hidden;position:absolute;top:0;width:1093px;z-index:1}.product-image img{display:block;height:100%;object-fit:contain;object-position:center;width:100%}.product-panel{border:1px solid var(--dark-baige,#a69684);border-radius:24px;height:467px;left:1024px;position:absolute;top:62px;width:837px;z-index:2}.product-text{color:var(--just-dark,#5c5958);font-family:var(--font-main,'Onest',sans-serif);font-size:24px;font-weight:500;line-height:1.1;margin:0;position:absolute;z-index:4}.product-text-1{height:182px;left:252px;top:145px;width:184px}.product-text-2{height:130px;left:782px;top:380px;width:184px}@media(max-width:1023px){.product{height:579px;min-height:579px}.product-stage{width:800px}.product-image{height:579px;left:-142px;opacity:1;top:0;width:950px}.product-panel{height:316px;left:567px;top:62px;width:586px}.product-text-1{height:170px;left:70px;top:399px;width:228px}.product-text-2{height:130px;left:426px;top:425px;width:184px}}@media(max-width:767px){.product-stage{width:390px}.product-image{height:500px;left:-394px;top:93px;width:821px}.product-panel{height:322px;left:380px;top:92px;width:399px}.product-text{font-size:18px}.product-text-1{height:100px;left:46px;top:46px;width:345px}.product-text-2{height:130px;left:99px;top:425px;width:184px}}
</style>
