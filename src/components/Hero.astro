---
import { PRIMARY_CONTACT_LINK } from '@/data/site';
---
<section id="top" class="section hero reveal" aria-labelledby="hero-title">
  <div class="container hero__grid">
    <div class="hero__copy card">
      <p>Для тех, кто живёт в напряжении, высокой ответственности и постоянном потоке задач</p>
      <p>и чувствует, что обычный отдых больше не восстанавливает.</p>
    </div>
    <div class="hero__scene" aria-hidden="true">
      <div class="figure figure--dark"></div>
      <div class="table"></div>
      <div class="figure figure--warm"></div>
      <div class="battery">70%</div>
    </div>
    <div class="hero__title">
      <h1 id="hero-title">Перезагрузка</h1>
      <p>без паузы от жизни</p>
      <div class="hero__actions">
        <a class="btn btn-primary" href={PRIMARY_CONTACT_LINK}>Индивидуально</a>
        <a class="btn btn-dark" href="#schedule">В группе</a>
      </div>
    </div>
  </div>
</section>
<style>
.hero{padding-top:24px}.hero__grid{min-height:620px;position:relative;display:grid;align-items:center;background:linear-gradient(120deg,#ece6da,#f8f3ea);overflow:hidden;border-radius:36px;padding:clamp(20px,5vw,56px)}
.hero__copy{max-width:520px;padding:24px;margin-left:auto;font-weight:800;color:var(--color-muted)}.hero__scene{position:absolute;inset:10% 4% 8%;}.figure{position:absolute;bottom:5%;width:18%;height:55%;border-radius:45% 45% 12% 12%;}.figure--dark{left:5%;background:var(--color-ink);opacity:.82}.figure--warm{right:12%;background:var(--color-warm-dark);opacity:.78}.table{position:absolute;left:23%;right:25%;bottom:28%;height:12px;background:rgba(48,52,59,.24);border-radius:99px}.battery{position:absolute;right:4%;top:18%;color:var(--color-warm-dark);font-weight:900;border:3px solid var(--color-warm);border-radius:10px;padding:28px 6px 4px}.hero__title{position:relative;align-self:end;text-align:center;z-index:2}.hero h1{font-size:clamp(3.2rem,12vw,9rem);line-height:.8;margin:0;text-transform:uppercase;color:white;text-shadow:0 8px 30px rgba(48,52,59,.18);letter-spacing:-.07em}.hero__title p{font-size:clamp(1.4rem,4vw,3rem);font-weight:800;margin:.2em 0 1rem}.hero__actions{display:flex;justify-content:center;gap:14px;flex-wrap:wrap}@media(max-width:720px){.hero__grid{min-height:680px}.hero__copy{margin:0;font-size:.9rem}.hero__scene{inset:24% 2% 18%}.figure{width:28%}.hero__actions .btn{min-width:150px}}
</style>
