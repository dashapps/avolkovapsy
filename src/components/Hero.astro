---
import { PRIMARY_CONTACT_LINK } from '@/data/site';
---
<section id="top" class="hero reveal" aria-labelledby="hero-title">
  <div class="hero__art" aria-hidden="true">
    <div class="hero__figure hero__figure--left">
      <div class="hero__head"></div>
      <div class="hero__body"></div>
      <div class="hero__seat"></div>
    </div>
    <div class="hero__table"></div>
    <div class="hero__figure hero__figure--right">
      <div class="hero__head"></div>
      <div class="hero__body"></div>
      <div class="hero__seat"></div>
    </div>
    <div class="hero__battery"></div>
  </div>

  <div class="hero__copy-card" aria-label="Описание аудитории">
    <p>Для тех, кто живёт<br />в напряжении, высокой ответственности<br />и постоянном потоке задач</p>
    <p>и чувствует, что обычный отдых больше<br />не восстанавливает.</p>
  </div>

  <div class="hero__title-card" aria-hidden="true"></div>

  <div class="hero__content">
    <div class="hero__heading-group">
      <h1 id="hero-title">Перезагрузка</h1>
      <p>без паузы от жизни</p>
    </div>
    <div class="hero__actions" aria-label="Форматы работы">
      <a class="hero__button hero__button--primary" href={PRIMARY_CONTACT_LINK}>Индивидуально</a>
      <a class="hero__button hero__button--dark" href="#schedule">В группе</a>
    </div>
  </div>
</section>

<style>
.hero,
.hero * { box-sizing: border-box; }

.hero {
  --hero-bg: var(--bg1, #dbd9d2);
  --hero-dark: var(--just-dark, #5c5958);
  --hero-content: var(--just-content, #302c2b);
  --hero-beige: var(--dark-baige, #a69684);
  --hero-primary: var(--primary, #fab842);
  --hero-title-fill: var(--cardtxtbg, rgba(255, 245, 233, 0.8));
  align-self: stretch;
  min-height: 778px;
  position: relative;
  overflow: hidden;
  background: var(--hero-bg);
}

.hero__art { position: absolute; inset: 0; z-index: 0; }
.hero__figure { position: absolute; }
.hero__figure--left { left: 0; top: 21px; width: 660px; height: 736px; }
.hero__figure--right { right: 0; top: 34px; width: 528px; height: 710px; }
.hero__head { position: absolute; width: 18%; aspect-ratio: 1; border-radius: 50%; background: currentColor; top: 15%; left: 47%; }
.hero__body { position: absolute; width: 34%; height: 46%; border-radius: 48% 48% 18% 18%; background: currentColor; top: 27%; left: 36%; transform: skew(-8deg); }
.hero__seat { position: absolute; width: 45%; height: 8%; border-radius: 999px; background: currentColor; left: 28%; bottom: 20%; opacity: .7; }
.hero__figure--left { color: rgba(48, 44, 43, .42); filter: grayscale(1); }
.hero__figure--right { color: rgba(250, 184, 66, .72); }
.hero__table { position: absolute; left: 31%; right: 30%; top: 47%; height: 12px; border-radius: 999px; background: rgba(92, 89, 88, .34); }
.hero__battery { position: absolute; right: 20px; top: 54px; width: 18px; height: 54px; border: 2px solid var(--hero-primary); border-radius: 5px; }
.hero__battery::before { content: ''; position: absolute; left: 5px; top: -6px; width: 4px; height: 4px; background: var(--hero-primary); border-radius: 2px 2px 0 0; }
.hero__battery::after { content: ''; position: absolute; inset: auto 3px 4px; height: 70%; background: linear-gradient(to top, #f05f4c 0 18%, var(--hero-primary) 18% 100%); border-radius: 2px; }

.hero__copy-card {
  position: absolute;
  left: 50%;
  top: 0;
  translate: -50%;
  width: 600px;
  min-height: 302px;
  padding: 75px 28px 28px;
  display: flex;
  flex-direction: column;
  gap: 28px;
  background: rgba(255, 245, 233, .3);
  border: solid var(--hero-beige);
  border-width: 0 1px 1px;
  border-radius: 0 0 24px 24px;
  z-index: 1;
}
.hero__copy-card p { width: min(467px, 100%); margin: 0 auto; color: var(--hero-dark); font-size: 21px; line-height: 1.3; font-weight: 400; }

.hero__title-card { position: absolute; left: 50%; top: 459px; translate: -50%; width: 633px; height: 225px; background: rgba(224, 218, 197, .6); border: 1px solid var(--hero-beige); border-radius: 24px; z-index: 1; }
.hero__content { position: absolute; left: 50%; top: 355px; translate: -50%; width: min(811px, calc(100% - 32px)); display: flex; flex-direction: column; align-items: center; gap: 26px; z-index: 2; }
.hero__heading-group { display: flex; flex-direction: column; align-items: center; width: 100%; }
.hero h1 { margin: 0; width: 100%; color: var(--hero-title-fill); text-align: right; font-size: 100px; line-height: 1.3; font-weight: 900; letter-spacing: -0.055em; text-transform: uppercase; -webkit-text-stroke: 1px var(--hero-beige); }
.hero__heading-group p { margin: 0; width: 100%; color: var(--hero-dark); text-align: center; font-size: 40px; line-height: 1.3; font-weight: 400; }
.hero__actions { display: flex; justify-content: center; gap: 24px; width: min(637px, 100%); }
.hero__button { flex: 1; display: inline-flex; align-items: center; justify-content: center; min-height: 78px; padding: 18px 24px; border-radius: 24px; font-size: 32px; line-height: 1.3; font-weight: 600; text-decoration: none; transition: transform .2s ease, box-shadow .2s ease; }
.hero__button:hover { transform: translateY(-2px); box-shadow: 0 16px 30px rgba(48, 44, 43, .12); }
.hero__button--primary { background: var(--hero-primary); color: var(--hero-dark); }
.hero__button--dark { background: var(--hero-dark); color: var(--hero-primary); }

@media (max-width: 900px) {
  .hero { min-height: 670px; }
  .hero__figure--left { left: -18px; top: -42px; width: 451px; height: 552px; }
  .hero__figure--right { left: 361px; right: auto; top: 55px; width: 508px; height: 696px; }
  .hero__copy-card { left: 267px; top: -35px; translate: 0; width: 308px; min-height: 402px; padding: 139px 20px 24px 36px; gap: 69px; background: rgba(248, 248, 248, .5); border: 1px solid var(--hero-beige); border-radius: 24px; }
  .hero__copy-card p { width: auto; margin: 0; color: var(--hero-content); font-size: 16px; }
  .hero__title-card { left: -37px; top: 409px; translate: 0; width: 524px; height: 156px; background: rgba(255, 255, 255, .41); }
  .hero__content { top: 312px; width: 811px; gap: 13px; }
  .hero__actions { width: auto; gap: 13px; }
  .hero h1 { font-size: 100px; }
  .hero__button { flex: 0 0 auto; min-height: 63px; font-size: 21px; }
}

@media (max-width: 560px) {
  .hero { min-height: 690px; }
  .hero__figure--left { left: -18px; top: -42px; width: 307px; height: 376px; }
  .hero__figure--right { left: 116px; top: 312px; width: 324px; height: 444px; }
  .hero__table, .hero__battery { display: none; }
  .hero__copy-card { left: 56px; top: -42px; width: 304px; min-height: 451px; padding: 95px 8px 24px 126px; gap: 58px; text-align: right; }
  .hero__copy-card p { color: var(--hero-content); text-align: right; font-size: 16px; }
  .hero__title-card { left: -37px; top: 431px; width: 252px; height: 141px; }
  .hero__content { left: 22px; top: 314px; translate: 0; width: calc(100% - 44px); align-items: flex-start; gap: 32px; }
  .hero__heading-group { align-items: flex-start; }
  .hero h1 { font-size: 46px; line-height: 1.3; text-align: left; letter-spacing: -0.04em; }
  .hero__heading-group p { order: 2; color: var(--hero-beige); text-align: left; font-size: 34px; line-height: 1.3; }
  .hero__actions { flex-direction: column; align-items: flex-start; }
  .hero__button { min-height: 63px; font-size: 21px; }
}
</style>
