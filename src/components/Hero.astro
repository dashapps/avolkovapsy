---
import { assets } from '@/data/assets';
import { PRIMARY_CONTACT_LINK } from '@/data/site';
---
<section id="top" class="hero reveal" aria-labelledby="hero-title" data-node-id="62:838">
  <div class="hero__stage">
    <div class="hero__visual-layer" aria-hidden="true" data-node-id="62:839">
      <picture class="hero__image hero__image--left" data-node-id="62:840">
        <source media="(max-width: 600px)" srcset={assets.hero.mobile.leftImage} />
        <source media="(max-width: 1023px)" srcset={assets.hero.tablet.leftImage} />
        <img src={assets.hero.desktop.leftImage} alt="" loading="eager" decoding="async" fetchpriority="high" />
      </picture>
      <picture class="hero__image hero__image--right" data-node-id="62:841">
        <source media="(max-width: 600px)" srcset={assets.hero.mobile.rightImage} />
        <source media="(max-width: 1023px)" srcset={assets.hero.tablet.rightImage} />
        <img src={assets.hero.desktop.rightImage} alt="" loading="eager" decoding="async" fetchpriority="high" />
      </picture>
    </div>

    <div class="hero__panel hero__panel--top" aria-hidden="true" data-node-id="62:842"></div>
    <div class="hero__panel hero__panel--bottom" aria-hidden="true" data-node-id="62:843"></div>

    <div class="hero__intro" data-node-id="62:852">
      <p data-node-id="62:853">Для тех, кто живёт<br />в напряжении, высокой ответственности<br />и постоянном потоке задач</p>
      <p data-node-id="62:854">и чувствует, что обычный отдых больше<br />не восстанавливает.</p>
    </div>

    <div class="hero__headline" data-node-id="62:844">
      <div class="hero__title-group" data-node-id="62:845">
        <h1 id="hero-title" data-node-id="62:846">ПЕРЕЗАГРУЗКА</h1>
        <p data-node-id="62:847">без паузы от жизни</p>
      </div>
      <div class="hero__buttons" data-node-id="62:848">
        <a class="hero__button hero__button--primary" href={PRIMARY_CONTACT_LINK} data-node-id="62:849">Индивидуально</a>
        <a class="hero__button hero__button--dark" href="#schedule" data-node-id="62:850">В группе</a>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  --bg1: #dbd9d2;
  --primary: #fab842;
  --just-dark: #5c5958;
  --dark-baige: #a69684;
  --cardtxtbg: rgba(255, 245, 233, 0.8);
  --panel-top: rgba(255, 245, 233, 0.3);
  --panel-bottom: rgba(224, 218, 197, 0.6);
  --shadow-title: 12px 24px 2px rgba(176, 156, 134, 0.4);
  --radius-panel: 24px;
  --radius-button: 24px;
  background: var(--bg1);
  height: 757px;
  min-height: 757px;
  overflow: hidden;
  padding: 0;
  position: relative;
  width: 100%;
}

.hero__stage {
  background: var(--bg1);
  height: 757px;
  left: 50%;
  overflow: hidden;
  position: absolute;
  top: 0;
  transform: translateX(-50%);
  width: 1280px;
}

.hero__visual-layer,
.hero__panel,
.hero__intro,
.hero__headline {
  position: absolute;
}

.hero__visual-layer {
  align-items: center;
  background: var(--bg1);
  display: flex;
  inset: 0;
  justify-content: space-between;
}

.hero__image {
  display: block;
  overflow: hidden;
  position: absolute;
}

.hero__image img {
  display: block;
  height: 100%;
  object-fit: cover;
  position: absolute;
  width: 100%;
}

.hero__image--left {
  height: 736px;
  left: 0;
  top: 10.5px;
  width: 660px;
}

.hero__image--left img {
  height: 101.5%;
  left: -5.55%;
  top: -0.79%;
  width: 92.48%;
}

.hero__image--right {
  height: 710px;
  left: 752px;
  top: 23.5px;
  width: 528px;
}

.hero__image--right img {
  height: 109.25%;
  left: -1.44%;
  top: -4.57%;
  width: 107.04%;
}

.hero__panel--top {
  background: var(--panel-top);
  border-bottom: 1px solid var(--dark-baige);
  border-left: 1px solid var(--dark-baige);
  border-radius: 0 0 var(--radius-panel) var(--radius-panel);
  border-right: 1px solid var(--dark-baige);
  height: 281px;
  left: 340px;
  top: 0;
  width: 604px;
}

.hero__panel--bottom {
  background: var(--panel-bottom);
  border: 1px solid var(--dark-baige);
  border-radius: var(--radius-panel);
  height: 225.155px;
  left: 324px;
  top: 437.766px;
  width: 633px;
}

.hero__intro {
  color: var(--just-dark);
  display: flex;
  flex-direction: column;
  font-family: var(--font-main, Onest, sans-serif);
  font-size: 21px;
  font-weight: 400;
  gap: 28px;
  height: 157.503px;
  left: 407px;
  line-height: 1.3;
  top: 54.052px;
  width: 467px;
  z-index: 2;
}

.hero__intro p {
  margin: 0;
}

.hero__headline {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 26px;
  height: 319.234px;
  left: 234px;
  top: 334.174px;
  width: 811px;
  z-index: 3;
}

.hero__title-group {
  text-align: center;
  width: 100%;
}

.hero h1 {
  color: var(--cardtxtbg);
  font-family: var(--font-main, Onest, sans-serif);
  font-size: 100px;
  font-weight: 900;
  letter-spacing: -0.045em;
  line-height: 1.3;
  margin: 0;
  text-align: right;
  text-shadow: var(--shadow-title);
  text-transform: uppercase;
}

.hero__title-group p {
  color: var(--just-dark);
  font-family: var(--font-main, Onest, sans-serif);
  font-size: 40px;
  font-weight: 400;
  line-height: 1.3;
  margin: 0;
  text-align: center;
}

.hero__buttons {
  align-items: flex-start;
  display: flex;
  gap: 24px;
  height: 94px;
  justify-content: center;
  width: 637px;
}

.hero__button {
  align-items: center;
  border-radius: var(--radius-button);
  display: flex;
  font-family: var(--font-main, Onest, sans-serif);
  font-size: 32px;
  font-weight: 600;
  height: 78px;
  justify-content: center;
  line-height: 1.3;
  padding: 18px 24px;
  text-decoration: none;
  transition: transform 0.2s ease;
  white-space: nowrap;
  width: 306.5px;
}

.hero__button:hover,
.hero__button:focus-visible {
  transform: translateY(-2px);
}

.hero__button--primary {
  background: var(--primary);
  color: var(--just-dark);
}

.hero__button--dark {
  background: var(--just-dark);
  color: var(--primary);
}

@media (max-width: 1023px) {
  .hero {
    height: 670px;
    min-height: 670px;
  }

  .hero__stage {
    height: 670px;
    width: 800px;
  }

  .hero__image--left {
    height: 650px;
    left: 0;
    top: 10px;
    width: 412px;
  }

  .hero__image--right {
    height: 620px;
    left: 470px;
    top: 24px;
    width: 330px;
  }

  .hero__panel--top {
    height: 250px;
    left: 210px;
    width: 380px;
  }

  .hero__panel--bottom {
    height: 198px;
    left: 96px;
    top: 430px;
    width: 608px;
  }

  .hero__intro {
    font-size: 18px;
    gap: 24px;
    left: 248px;
    top: 50px;
    width: 304px;
  }

  .hero__headline {
    gap: 22px;
    left: 68px;
    top: 340px;
    width: 664px;
  }

  .hero h1 {
    font-size: 82px;
  }

  .hero__title-group p {
    font-size: 34px;
  }

  .hero__buttons {
    gap: 20px;
    width: 590px;
  }

  .hero__button {
    font-size: 28px;
    height: 72px;
    width: 285px;
  }
}

@media (max-width: 600px) {
  .hero {
    height: 690px;
    min-height: 690px;
  }

  .hero__stage {
    height: 690px;
    width: 390px;
  }

  .hero__image--left {
    height: 520px;
    left: -58px;
    top: 128px;
    width: 294px;
  }

  .hero__image--right {
    height: 536px;
    left: 174px;
    top: 126px;
    width: 248px;
  }

  .hero__panel--top {
    height: 230px;
    left: 24px;
    width: 342px;
  }

  .hero__panel--bottom {
    height: 178px;
    left: 16px;
    top: 478px;
    width: 358px;
  }

  .hero__intro {
    font-size: 16px;
    gap: 20px;
    left: 44px;
    top: 42px;
    width: 302px;
  }

  .hero__headline {
    gap: 18px;
    left: 11px;
    top: 376px;
    width: 368px;
  }

  .hero h1 {
    font-size: 47px;
    letter-spacing: -0.04em;
    text-align: center;
    text-shadow: 6px 12px 1px rgba(176, 156, 134, 0.4);
  }

  .hero__title-group p {
    font-size: 28px;
  }

  .hero__buttons {
    flex-direction: column;
    gap: 12px;
    height: auto;
    width: 306px;
  }

  .hero__button {
    font-size: 24px;
    height: 62px;
    width: 306px;
  }
}
</style>
