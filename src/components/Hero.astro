---
import { assets } from '@/data/assets';
import { PRIMARY_CONTACT_LINK } from '@/data/site';

const hasHeroImages = Object.values(assets.hero).some((breakpoint) => breakpoint.leftImage || breakpoint.rightImage);
---
<section id="top" class="section hero reveal" aria-labelledby="hero-title">
  <div class="container hero__grid">
    <div class="hero__copy card">
      <p>Для тех, кто живёт в напряжении, высокой ответственности и постоянном потоке задач</p>
      <p>и чувствует, что обычный отдых больше не восстанавливает.</p>
    </div>
    {hasHeroImages && (
      <div class="hero__scene" aria-hidden="true">
        {assets.hero.desktop.leftImage && <img class="hero__image hero__image--left hero__image--desktop" src={assets.hero.desktop.leftImage} alt="" loading="eager" decoding="async" />}
        {assets.hero.desktop.rightImage && <img class="hero__image hero__image--right hero__image--desktop" src={assets.hero.desktop.rightImage} alt="" loading="eager" decoding="async" />}
        {assets.hero.tablet.leftImage && <img class="hero__image hero__image--left hero__image--tablet" src={assets.hero.tablet.leftImage} alt="" loading="eager" decoding="async" />}
        {assets.hero.tablet.rightImage && <img class="hero__image hero__image--right hero__image--tablet" src={assets.hero.tablet.rightImage} alt="" loading="eager" decoding="async" />}
        {assets.hero.mobile.leftImage && <img class="hero__image hero__image--left hero__image--mobile" src={assets.hero.mobile.leftImage} alt="" loading="eager" decoding="async" />}
        {assets.hero.mobile.rightImage && <img class="hero__image hero__image--right hero__image--mobile" src={assets.hero.mobile.rightImage} alt="" loading="eager" decoding="async" />}
      </div>
    )}
    <div class="hero__title">
      <h1 id="hero-title">Перезагрузка</h1>
      <p>без паузы от жизни</p>
      <div class="hero__actions">
        <a class="btn btn-primary" href={PRIMARY_CONTACT_LINK}>Индивидуально</a>
        <a class="btn btn-dark" href="#schedule">В группе</a>
      </div>
    </div>
  </div>
</section>
<style>
.hero{padding-top:24px}.hero__grid{min-height:620px;position:relative;display:grid;align-items:center;background:linear-gradient(120deg,#ece6da,#f8f3ea);overflow:hidden;border-radius:36px;padding:clamp(20px,5vw,56px)}
.hero__copy{max-width:520px;padding:24px;margin-left:auto;font-weight:800;color:var(--color-muted)}.hero__scene{position:absolute;inset:10% 4% 8%;pointer-events:none}.hero__image{position:absolute;bottom:0;max-height:100%;width:auto;object-fit:contain}.hero__image--left{left:0}.hero__image--right{right:0}.hero__image--tablet,.hero__image--mobile{display:none}.hero__title{position:relative;align-self:end;text-align:center;z-index:2}.hero h1{font-size:clamp(3.2rem,12vw,9rem);line-height:.8;margin:0;text-transform:uppercase;color:white;text-shadow:0 8px 30px rgba(48,52,59,.18);letter-spacing:-.07em}.hero__title p{font-size:clamp(1.4rem,4vw,3rem);font-weight:800;margin:.2em 0 1rem}.hero__actions{display:flex;justify-content:center;gap:14px;flex-wrap:wrap}@media(max-width:1024px){.hero__image--desktop{display:none}.hero__image--tablet{display:block}}@media(max-width:720px){.hero__grid{min-height:680px}.hero__copy{margin:0;font-size:.9rem}.hero__scene{inset:24% 2% 18%}.hero__image--tablet{display:none}.hero__image--mobile{display:block}.hero__actions .btn{min-width:150px}}
</style>
