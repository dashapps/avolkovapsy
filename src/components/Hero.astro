---
import { assets } from '@/data/assets';
import { PRIMARY_CONTACT_LINK } from '@/data/site';
---
<section id="top" class="hero reveal" aria-labelledby="hero-title" data-node-id="62:838">
  <div class="hero__stage">
    <div class="hero__visual-layer" aria-hidden="true" data-node-id="62:839">
      <picture class="hero__image hero__image--left" data-node-id="62:840">
        <source media="(max-width: 600px)" srcset={assets.hero.mobile.leftImage} />
        <source media="(max-width: 1023px)" srcset={assets.hero.tablet.leftImage} />
        <img src={assets.hero.desktop.leftImage} alt="" loading="eager" decoding="async" fetchpriority="high" />
      </picture>
      <picture class="hero__image hero__image--right" data-node-id="62:841">
        <source media="(max-width: 600px)" srcset={assets.hero.mobile.rightImage} />
        <source media="(max-width: 1023px)" srcset={assets.hero.tablet.rightImage} />
        <img src={assets.hero.desktop.rightImage} alt="" loading="eager" decoding="async" fetchpriority="high" />
      </picture>
    </div>

    <div class="hero__panel hero__panel--top" aria-hidden="true" data-node-id="62:842"></div>
    <div class="hero__panel hero__panel--bottom" aria-hidden="true" data-node-id="62:843"></div>

    <div class="hero__intro" data-node-id="62:852">
      <p data-node-id="62:853">Для тех, кто живёт<br />в напряжении, высокой ответственности<br />и постоянном потоке задач</p>
      <p data-node-id="62:854">и чувствует, что обычный отдых больше<br />не восстанавливает.</p>
    </div>

    <div class="hero__headline" data-node-id="62:844">
      <div class="hero__title-group" data-node-id="62:845">
        <h1 id="hero-title" class="hero-title" data-node-id="62:846">ПЕРЕЗАГРУЗКА</h1>
        <p data-node-id="62:847">без паузы от жизни</p>
      </div>
      <div class="hero__buttons" data-node-id="62:848">
        <a class="hero__button hero__button--primary" href={PRIMARY_CONTACT_LINK} data-node-id="62:849">Индивидуально</a>
        <a class="hero__button hero__button--dark" href="#schedule" data-node-id="62:850">В группе</a>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  --bg1: #dbd9d2;
  --primary: #fab842;
  --liteyell: #fde5ba;
  --just-dark: #5c5958;
  --just-content: #302c2b;
  --dark-baige: #a69684;
  --panel-top: rgba(255, 245, 233, 0.3);
  --panel-bottom: rgba(224, 218, 197, 0.6);
  --shadow-title: 12px 24px 2px rgba(176, 156, 134, 0.4);
  --radius-panel: 24px;
  --radius-button: 24px;
  background: var(--bg1);
  height: 670px;
  min-height: 670px;
  overflow: hidden;
  padding: 0;
  position: relative;
  width: 100%;
}

.hero,
.hero * {
  box-sizing: border-box;
}

.hero__stage {
  background: var(--bg1);
  height: 670px;
  left: 50%;
  overflow: hidden;
  position: absolute;
  top: 0;
  transform: translateX(-50%);
  width: 1280px;
}

.hero__visual-layer,
.hero__panel,
.hero__intro,
.hero__headline {
  position: absolute;
}

.hero__visual-layer {
  background: var(--bg1);
  height: 670px;
  left: 0;
  top: 0;
  width: 1280px;
}

.hero__image {
  display: block;
  overflow: hidden;
  position: absolute;
}

.hero__image img {
  display: block;
  object-fit: cover;
  position: absolute;
}

.hero__image--left {
  height: 736px;
  left: 0;
  top: -33px;
  width: 660px;
}

.hero__image--left img {
  height: 101.5%;
  left: -5.55%;
  top: -0.79%;
  width: 92.48%;
}

.hero__image--right {
  height: 710px;
  left: 752px;
  top: -20px;
  width: 528px;
}

.hero__image--right img {
  height: 109.25%;
  left: -1.44%;
  top: -4.57%;
  width: 107.04%;
}

.hero__panel--top {
  background: var(--panel-top);
  border-bottom: 1px solid var(--dark-baige);
  border-left: 1px solid var(--dark-baige);
  border-radius: 0 0 var(--radius-panel) var(--radius-panel);
  border-right: 1px solid var(--dark-baige);
  height: 248.705px;
  left: 340px;
  top: 0;
  width: 604px;
}

.hero__panel--bottom {
  background: var(--panel-bottom);
  border: 1px solid var(--dark-baige);
  border-radius: var(--radius-panel);
  height: 190.291px;
  left: 395px;
  top: 387.662px;
  width: 410px;
}

.hero__intro {
  color: var(--just-dark);
  display: flex;
  flex-direction: column;
  font-family: var(--font-main, Onest, sans-serif);
  font-size: 21px;
  font-weight: 400;
  gap: 28px;
  height: 139.401px;
  left: 407px;
  line-height: 1.3;
  top: 77px;
  width: 467px;
  z-index: 2;
}

.hero__intro p {
  margin: 0;
}

.hero__headline {
  height: 282.545px;
  left: 234px;
  top: 273px;
  width: 811px;
  z-index: 3;
}

.hero__title-group {
  height: 182px;
  left: 0;
  position: absolute;
  text-align: center;
  top: 0;
  width: 811px;
}

.hero-title {
  color: var(--liteyell, #fde5ba);
  font-family: "Onest", sans-serif;
  font-size: 100px;
  font-weight: 900;
  letter-spacing: -0.045em;
  line-height: 1.3;
  margin: 0;
  text-align: right;
  -webkit-text-fill-color: var(--liteyell, #fde5ba);
  -webkit-text-stroke: 1px rgba(92, 89, 88, 0.22);
  text-shadow: 12px 24px 2px rgba(176, 156, 134, 0.4);
  text-stroke: 1px rgba(92, 89, 88, 0.22);
  text-transform: uppercase;
}

.hero__title-group p {
  color: var(--just-dark);
  font-family: var(--font-main, Onest, sans-serif);
  font-size: 40px;
  font-weight: 400;
  line-height: 1.3;
  margin: 0;
  text-align: center;
}

.hero__buttons {
  align-items: flex-start;
  display: flex;
  gap: 24px;
  height: 94px;
  justify-content: center;
  left: 87px;
  position: absolute;
  top: 208px;
  width: 637px;
}

.hero__button {
  align-items: center;
  border-radius: var(--radius-button);
  display: flex;
  font-family: var(--font-main, Onest, sans-serif);
  font-size: 32px;
  font-weight: 600;
  height: 78px;
  justify-content: center;
  line-height: 1.3;
  padding: 18px 24px;
  text-decoration: none;
  transition: transform 0.2s ease;
  white-space: nowrap;
  width: 306.5px;
}

.hero__button:hover,
.hero__button:focus-visible {
  transform: translateY(-2px);
}

.hero__button--primary {
  background: var(--primary);
  color: var(--just-dark);
}

.hero__button--dark {
  background: var(--just-dark);
  color: var(--primary);
}

@media (max-width: 1023px) {
  .hero {
    height: 670px;
    min-height: 670px;
  }

  .hero__stage,
  .hero__visual-layer {
    height: 670px;
    width: 800px;
  }

  .hero__image--left {
    height: 552px;
    left: -18px;
    top: -42px;
    width: 451px;
  }

  .hero__image--right {
    height: 696px;
    left: 361px;
    top: 55px;
    width: 508px;
  }

  .hero__panel--top {
    background: rgba(248, 248, 248, 0.5);
    border: 1px solid var(--dark-baige);
    border-radius: var(--radius-panel);
    height: 402px;
    left: 267px;
    top: -35px;
    width: 308px;
  }

  .hero__panel--bottom {
    background: rgba(255, 255, 255, 0.41);
    height: 156px;
    left: -37px;
    top: 409px;
    width: 524px;
  }

  .hero__intro {
    color: var(--just-content);
    display: block;
    font-size: 16px;
    height: auto;
    left: 0;
    line-height: 1.3;
    top: 0;
    width: 800px;
  }

  .hero__intro p {
    position: absolute;
  }

  .hero__intro p:first-child {
    height: 84px;
    left: 303px;
    text-align: left;
    top: 104px;
    width: 231px;
  }

  .hero__intro p:last-child {
    height: 84px;
    left: 386px;
    text-align: left;
    top: 218px;
    width: 170px;
  }

  .hero__headline {
    height: 282.545px;
    left: 0;
    top: 312px;
    width: 811px;
  }

  .hero-title {
    font-size: 100px;
  }

  .hero__title-group p {
    font-size: 40px;
  }

  .hero__buttons {
    gap: 13px;
    height: 63px;
    left: 89px;
    top: 208px;
    width: 363px;
  }

  .hero__button {
    font-size: 21px;
    height: 63px;
    padding: 18px 24px;
    width: 175px;
  }
}

@media (max-width: 600px) {
  .hero {
    height: 690px;
    min-height: 690px;
  }

  .hero__stage,
  .hero__visual-layer {
    height: 690px;
    width: 390px;
  }

  .hero__image--left {
    height: 376px;
    left: -18px;
    top: -42px;
    width: 307px;
  }

  .hero__image--right {
    height: 444px;
    left: 116px;
    top: 312px;
    width: 324px;
  }

  .hero__panel--top {
    height: 451px;
    left: 56px;
    top: -42px;
    width: 304px;
  }

  .hero__panel--bottom {
    height: 141px;
    left: -37px;
    top: 431px;
    width: 252px;
  }

  .hero__intro {
    color: var(--just-content);
    font-size: 16px;
    height: auto;
    left: 0;
    top: 0;
    width: 390px;
  }

  .hero__intro p:first-child {
    height: 126px;
    left: 192px;
    text-align: right;
    top: 53px;
    width: 160px;
  }

  .hero__intro p:last-child {
    height: 84px;
    left: 182px;
    text-align: right;
    top: 216px;
    width: 170px;
  }

  .hero__headline {
    height: 275px;
    left: 22px;
    top: 314px;
    width: 346px;
  }

  .hero__title-group {
    height: 90px;
    width: 346px;
  }

  .hero-title {
    font-size: 46px;
    letter-spacing: -0.04em;
    line-height: 1.3;
    text-align: left;
    -webkit-text-stroke: 0.7px rgba(92, 89, 88, 0.22);
    text-shadow: 6px 12px 2px rgba(153, 153, 150, 0.42);
    text-stroke: 0.7px rgba(92, 89, 88, 0.22);
  }

  .hero__title-group p {
    font-size: 34px;
    line-height: 1.3;
    margin-top: -15px;
    text-align: left;
  }

  .hero__buttons {
    flex-direction: column;
    gap: 13px;
    height: 139px;
    left: -5px;
    top: 136px;
    width: 211px;
  }

  .hero__button {
    font-size: 21px;
    height: 63px;
    padding: 18px 24px;
    width: 211px;
  }
}
</style>
