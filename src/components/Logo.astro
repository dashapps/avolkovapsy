---
import BatteryIcon from '@/components/BatteryIcon.astro';
---
<span class="logo" data-node-id="88:419">
  <BatteryIcon />
  <span class="logo-text logo-text--full">Александра<br />ВОлкова</span>
  <span class="logo-text logo-text--compact">АВ</span>
</span>

<style>
.logo {
  align-items: center;
  color: var(--just-dark, #5c5958);
  display: inline-flex;
  gap: 14px;
  min-width: 0;
}

.logo-text {
  font-family: var(--font-main, 'Onest', sans-serif);
  font-weight: 900;
  text-shadow: 6px 12px 2px rgba(176, 156, 134, 0.4);
  text-transform: uppercase;
  white-space: nowrap;
}

.logo-text--full {
  color: var(--just-dark, #5c5958);
  font-size: 32px;
  line-height: 0.9;
}

.logo-text--compact {
  color: var(--cardtxtbg, rgba(255, 245, 233, 0.8));
  display: none;
  font-size: 32px;
  letter-spacing: -6.4px;
  line-height: 1.3;
}

@media (max-width: 600px) {
  .logo {
    gap: 12px;
  }

  .logo-text--full {
    display: none;
  }

  .logo-text--compact {
    display: inline-block;
  }
}
</style>
