---
import { scheduleItems } from '@/data/schedule';
const visibleItems = scheduleItems.filter((item) => item.active || item.id === 'consultation');
---
<section id="schedule" class="section schedule" aria-labelledby="schedule-title"><div class="container"><h2 id="schedule-title" class="section-title">Ближайшие <span>форматы</span></h2><div class="schedule__grid">{visibleItems.map((item) => (<article class:list={['card','schedule__card', item.id === 'consultation' && 'schedule__card--dark']}><h3>{item.title}</h3><dl>{item.date && <><dt>Дата</dt><dd>{item.date}</dd></>}{item.time && <><dt>Время</dt><dd>{item.time}</dd></>}<dt>Формат</dt><dd>{item.format}</dd>{item.location && <><dt>Место</dt><dd>{item.location}</dd></>}<dt>Стоимость</dt><dd>{item.price}</dd></dl><p>{item.description}</p><a class="btn btn-primary" href={item.button_url}>{item.button_text}</a></article>))}</div></div></section>
<style>.schedule{background:var(--color-warm)}.section-title span{color:#fff}.schedule__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:28px}.schedule__card{padding:24px}.schedule__card--dark{background:var(--color-ink);color:white}.schedule h3{font-size:1.35rem;margin:0 0 18px}dl{display:grid;grid-template-columns:88px 1fr;gap:8px;margin:0}dt{color:var(--color-muted);font-weight:800}.schedule__card--dark dt{color:#f7bd3b}dd{margin:0;font-weight:900}p{font-weight:700;color:inherit;opacity:.82}@media(max-width:850px){.schedule__grid{grid-template-columns:1fr}}</style>
